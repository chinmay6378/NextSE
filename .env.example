# ── Root-level .env used by docker-compose ────────────────────────────────────
# Copy this to .env and fill in real values.
# Backend secrets live in Backend/.env separately.

# Supabase (needed at frontend BUILD time — must match Backend/.env values)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# In production this is https://yourdomain.com/api
# nginx strips /api and proxies to the backend container
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api
