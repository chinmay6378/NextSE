# --- Supabase (Project Settings -> API / Database) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=client-files

# Postgres connection string. Use the DIRECT connection or SESSION pooler
# (port 5432) — NOT the transaction pooler (port 6543), which breaks asyncpg's
# prepared statements under SQLAlchemy's async engine.
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- OpenAI (used for structured scoring only) ---
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Groq (STT + LLM for voice pipeline) ---
GROQ_API_KEY=

# --- ElevenLabs (TTS for voice pipeline) ---
ELEVENLABS_API_KEY=

# --- App ---
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# --- Certification config ---
MCQ_DEFAULT_QUESTION_COUNT=10
MCQ_PASS_THRESHOLD_PERCENT=70.0
